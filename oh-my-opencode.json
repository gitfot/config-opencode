{
	"$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
	"runtime_fallback": {
		"enabled": true,
		"retry_on_errors": [
			400,
			429,
			500,
			503,
			529
		],
		"max_fallback_attempts": 3,
		"cooldown_seconds": 60,
		"timeout_seconds": 60,
		"notify_on_fallback": true
	},
	"agents": {
		"sisyphus": {
			"model": "newapi-oai/gpt-5.4",
			"temperature": 0.1,
			"variant": "high",
			"fallback_models": [
				"newapi-oai/gpt-5.3-codex",
				"newapi-oai/gpt-5.2-codex",
			]
		},
		"atlas": {
			"model": "newapi-oai/gpt-5.4",
			"temperature": 0.1,
			"fallback_models": [
				"newapi-oai/gpt-5.3-codex"
			]
		},
		"prometheus": {
			"model": "newapi-oai/gpt-5.4",
			"temperature": 0.1,
			"fallback_models": [
				"newapi-oai/gpt-5.3-codex"
			]
		},
		"metis": {
			"model": "newapi-oai/gpt-5.4",
			"temperature": 0.3,
			"variant": "max",
			"fallback_models": [
				"newapi-oai/gpt-5.3-codex"
			]
		},
		"momus": {
			"model": "newapi-oai/gpt-5.4",
			"temperature": 0.1,
			"variant": "medium",
			"fallback_models": [
				"newapi-oai/gpt-5.2",
				"newapi-gemini/gemini-3-pro-preview"
			]
		},
		"hephaestus": {
			"model": "newapi-oai/gpt-5.4",
			"temperature": 0.1,
			"variant": "xhigh",
			"fallback_models": [
				"newapi-oai/gpt-5.3-codex"
			]
		},
		"oracle": {
			"model": "newapi-oai/gpt-5.4",
			"temperature": 0.1,
			"variant": "xhigh",
			"fallback_models": [
				"newapi-gemini/gemini-3-pro-preview",
				"newapi-oai/gpt-5.2"
			]
		},
		"librarian": {
			"model": "newapi-oai/gpt-5.3-codex-spark",
			"fallback_models": [
				"newapi-gemini/gemini-3-flash-preview"
			]
		},
		"explore": {
			"model": "newapi-oai/gpt-5.3-codex-spark",
			"fallback_models": [
				"newapi-gemini/gemini-3-flash-preview"
			]
		},
		"multimodal-looker": {
			"model": "newapi-gemini/gemini-3-pro-preview",
			"fallback_models": [
				"newapi-gemini/gemini-3-flash-preview"
			]
		}
	},
	"categories": {
		"quick": {
			"model": "newapi-oai/gpt-5.3-codex-spark",
			"temperature": 0.1
		},
		"deep": {
			"model": "newapi-oai/gpt-5.4",
			"variant": "medium",
			"temperature": 0.1
		},
		"ultrabrain": {
			"model": "newapi-oai/gpt-5.4",
			"variant": "xhigh",
			"temperature": 0.1
		},
		"visual-engineering": {
			"model": "newapi-gemini/gemini-3-pro-preview",
			"temperature": 0.1
		},
		"writing": {
			"model": "newapi-gemini/gemini-3-pro-preview",
			"temperature": 0.2
		},
		"unspecified-low": {
			"model": "newapi-oai/gpt-5.4",
			"temperature": 0.1
		},
		"unspecified-high": {
			"model": "newapi-oai/gpt-5.4",
			"variant": "max",
			"temperature": 0.1
		}
	}
}