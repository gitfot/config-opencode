{
	"plugin": [
		"oh-my-opencode@latest",
		"@tarquinen/opencode-dcp@latest"
	],
	"skills": {
        "paths": ["/home/wanwan/.agents/skills"]
     },
	"model": "newapi-oai/gpt-5.4",
	"$schema": "https://opencode.ai/config.json",
	"autoupdate": "notify",
	"provider": {
		"newapi-oai": {
			"npm": "@ai-sdk/openai",
			"name": "newapi-oai",
			"options": {
				"baseURL": "https://api.204502.xyz/v1",
				"setCacheKey": true
			},
			"models": {
				"gpt-5.3-codex": {
					"name": "gpt-5.3-codex",
					"thinking": true,
					"limit": {
						"context": 400000,
						"output": 128000
					},
					"modalities": {
						"input": [
							"text",
							"image"
						],
						"output": [
							"text"
						]
					},
					"options": {
						"include": [
							"reasoning.encrypted_content"
						],
						"store": false
					},
					"variants": {
						"xhigh": {
							"reasoningEffort": "xhigh",
							"textVerbosity": "medium",
							"reasoningSummary": "auto"
						},
						"high": {
							"reasoningEffort": "high",
							"textVerbosity": "medium",
							"reasoningSummary": "auto"
						},
						"medium": {
							"reasoningEffort": "medium",
							"textVerbosity": "medium",
							"reasoningSummary": "auto"
						},
						"low": {
							"reasoningEffort": "low",
							"textVerbosity": "medium",
							"reasoningSummary": "auto"
						}
					}
				},
				"gpt-5.3-codex-spark": {
					"name": "gpt-5.3-codex-spark",
					"variants": {
						"xhigh": {
							"reasoningEffort": "xhigh",
							"textVerbosity": "medium",
							"reasoningSummary": "auto"
						},
						"high": {
							"reasoningEffort": "high",
							"textVerbosity": "medium",
							"reasoningSummary": "auto"
						},
						"medium": {
							"reasoningEffort": "medium",
							"textVerbosity": "medium",
							"reasoningSummary": "auto"
						},
						"low": {
							"reasoningEffort": "low",
							"textVerbosity": "medium",
							"reasoningSummary": "auto"
						}
					}
				},
				"gpt-5.4": {
					"name": "gpt-5.4",
					"limit": {
						"context": 1050000,
						"output": 128000
					},
					"attachment": true,
					"reasoning": true,
					"tool_call": true,
					"temperature": false,
					"modalities": {
						"input": [
							"text",
							"image"
						],
						"output": [
							"text"
						]
					},
					"options": {
						"include": [
							"reasoning.encrypted_content"
						],
						"store": false
					},
					"variants": {
						"xhigh": {
							"reasoningEffort": "xhigh",
							"textVerbosity": "medium",
							"reasoningSummary": "auto"
						},
						"high": {
							"reasoningEffort": "high",
							"textVerbosity": "medium",
							"reasoningSummary": "auto"
						},
						"medium": {
							"reasoningEffort": "medium",
							"textVerbosity": "medium",
							"reasoningSummary": "auto"
						},
						"low": {
							"reasoningEffort": "low",
							"textVerbosity": "medium",
							"reasoningSummary": "auto"
						}
					}
				}
			}
		},
		"newapi-claude": {
			"npm": "@ai-sdk/anthropic",
			"name": "newapi-claude",
			"options": {
				"baseURL": "https://api.204502.xyz/v1"
			},
			"models": {
				"claude-opus-4-6": {
					"name": "claude-opus-4-6",
					"thinking": true,
					"limit": {
						"context": 200000,
						"output": 64000
					},
					"modalities": {
						"input": [
							"text",
							"image",
							"pdf"
						],
						"output": [
							"text"
						]
					}
				},
				"claude-sonnet-4-6": {
					"name": "claude-sonnet-4-6",
					"thinking": true,
					"limit": {
						"context": 200000,
						"output": 64000
					},
					"modalities": {
						"input": [
							"text",
							"image",
							"pdf"
						],
						"output": [
							"text"
						]
					}
				},
				"claude-haiku-4-5": {
					"name": "claude-haiku-4-5",
					"thinking": true
				}
			}
		},
		"newapi-gemini": {
			"npm": "@ai-sdk/google",
			"name": "newapi-gemini",
			"options": {
				"baseURL": "https://api.204502.xyz/v1beta"
			},
			"models": {
				"gemini-3-pro-preview": {
					"name": "gemini-3-pro-preview",
					"thinking": true,
					"limit": {
						"context": 1048576,
						"output": 65536
					},
					"modalities": {
						"input": [
							"text",
							"image",
							"pdf"
						],
						"output": [
							"text"
						]
					},
					"variants": {
						"high": {
							"thinkingConfig": {
								"includeThoughts": true,
								"thinkingLevel": "high"
							}
						},
						"low": {
							"thinkingConfig": {
								"includeThoughts": true,
								"thinkingLevel": "low"
							}
						}
					}
				},
				"gemini-3.1-pro-preview": {
					"name": "gemini-3.1-pro-preview",
					"thinking": true,
					"limit": {
						"context": 1048576,
						"output": 65536
					},
					"modalities": {
						"input": [
							"text",
							"image",
							"pdf"
						],
						"output": [
							"text"
						]
					},
					"variants": {
						"high": {
							"thinkingConfig": {
								"includeThoughts": true,
								"thinkingLevel": "high"
							}
						},
						"low": {
							"thinkingConfig": {
								"includeThoughts": true,
								"thinkingLevel": "low"
							}
						}
					}
				},
				"gemini-3-flash-preview": {
					"name": "gemini-3-flash-preview",
					"thinking": true,
					"modalities": {
						"input": [
							"text",
							"image",
							"pdf"
						],
						"output": [
							"text"
						]
					}
				}
			}
		}
	},
	"permission": {
		"bash": {
			"*": "ask",
			"ls *": "allow",
			"cat *": "allow",
			"head *": "allow",
			"tail *": "allow",
			"find *": "allow",
			"grep *": "allow",
			"pwd": "allow",
			"echo *": "allow",
			"which *": "allow",
			"type *": "allow",
			"file *": "allow",
			"stat *": "allow",
			"wc *": "allow",
			"diff *": "allow",
			"git status*": "allow",
			"git log*": "allow",
			"git diff*": "allow",
			"git show*": "allow",
			"git branch*": "allow"
		}
	},
	"compaction": {
		"auto": true,
		"prune": true
	},
	"watcher": {
		"ignore": [
			"node_modules/**",
			"dist/**",
			".git/**",
			"*.log"
		]
	}
}